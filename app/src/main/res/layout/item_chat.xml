<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:orientation="horizontal"
    android:padding="12dp"
    android:background="?android:attr/selectableItemBackground">

    <!-- Аватар с историей (круглый) -->
    <FrameLayout
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center_vertical">

        <androidx.cardview.widget.CardView
            android:id="@+id/storyRing"
            android:layout_width="52dp"
            android:layout_height="52dp"
            app:cardCornerRadius="26dp"
            app:cardElevation="0dp"
            android:backgroundTint="#26A5E4"
            android:layout_gravity="center"
            android:visibility="gone">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </androidx.cardview.widget.CardView>

        <!-- Круглый аватар -->
        <androidx.cardview.widget.CardView
            android:id="@+id/avatarContainer"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            android:backgroundTint="#00000000">

            <TextView
                android:id="@+id/avatarText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

        </androidx.cardview.widget.CardView>

        <!-- Индикатор новых сообщений -->
        <TextView
            android:id="@+id/unreadBadge"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="top|end"
            android:background="@drawable/unread_badge"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Информация о чате -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:orientation="vertical"
        android:layout_gravity="center_vertical">

        <TextView
            android:id="@+id/chatName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Имя"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/chatMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Сообщение"
                android:textColor="#8D8D93"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

    </LinearLayout>

    <!-- Время и галочки -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Галочки слева от времени -->
        <LinearLayout
            android:id="@+id/checkmarksContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginEnd="4dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/checkmark1"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_check_single"
                android:tint="#8D8D93" />

        </LinearLayout>

        <TextView
            android:id="@+id/chatTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10:30"
            android:textColor="#8D8D93"
            android:textSize="12sp" />

    </LinearLayout>

</LinearLayout>